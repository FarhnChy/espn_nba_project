NBA_DATA_PROVIDER=demo

# To use BALLDONTLIE free/basic real data:
# 1. Create a free account at https://app.balldontlie.io/
# 2. Put the API key in your local .env file, not in Git.
# 3. Change NBA_DATA_PROVIDER to balldontlie.
#
# NBA_DATA_PROVIDER=balldontlie
# BALLDONTLIE_API_KEY=your_api_key_here
#
# Optional: request a specific game date. Useful during the NBA offseason.
# NBA_DATA_DATE=2026-02-20
